<?xml version="1.0" encoding="UTF-8" ?>
<Report xmlns="http://soap.sforce.com/2006/04/metadata">
    <name>Open Provisioning Tasks</name>
    <description
  >Every provisioning task that isn't yet complete, for the Provisioning team's daily worklist.</description>
    <format>Tabular</format>
    <reportType>Provisioning_Task_Report</reportType>
    <scope>Provisioning_Task__c</scope>
    <showDetails>true</showDetails>
    <columns>
        <field>Name</field>
    </columns>
    <columns>
        <field>Service_Order__c</field>
    </columns>
    <columns>
        <field>Task_Type__c</field>
    </columns>
    <columns>
        <field>Status__c</field>
    </columns>
    <columns>
        <field>Assigned_Queue__c</field>
    </columns>
    <columns>
        <field>Due_Date__c</field>
    </columns>
    <filter>
        <criteriaItems>
            <column>Status__c</column>
            <operator>notEqual</operator>
            <value>Complete</value>
        </criteriaItems>
    </filter>
    <sortColumn>Due_Date__c</sortColumn>
    <sortOrder>Asc</sortOrder>
</Report>
